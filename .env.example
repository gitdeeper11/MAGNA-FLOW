# MAGNA-FLOW Environment Variables Example (E-LAB-09)
# Neural Magnetohydrodynamic Dissipation Control for High-Conductivity Turbulent Plasma Systems

# ============= MHD Parameters =============
MAGNA_FLOW_SPATIAL_DIM=256
MAGNA_FLOW_K_MAX=64
MAGNA_FLOW_MFNO_LAYERS=8
MAGNA_FLOW_HIDDEN_CHANNELS=256

# ============= Control Parameters =============
MAGNA_FLOW_LFLUX_HORIZON_US=500
MAGNA_FLOW_LFLUX_TIMESTEP_US=50
MAGNA_FLOW_LAMBDA_SAFE=0.05
MAGNA_FLOW_B_MAX=1.2

# ============= Physics Constraints =============
MAGNA_FLOW_LAMBDA_1=1.0
MAGNA_FLOW_LAMBDA_2=8.0
MAGNA_FLOW_LAMBDA_3=12.0
MAGNA_FLOW_LAMBDA_4=4.0

# ============= Fluid Substrate =============
MAGNA_FLOW_FLUID=plasma_deuterium
MAGNA_FLOW_REGIME=tokamak_elm
MAGNA_FLOW_ENFORCE_HELICITY=true

# ============= Hardware Deployment =============
MAGNA_FLOW_TENSORRT_ENABLE=false
MAGNA_FLOW_FPGA_TARGET=orin
MAGNA_FLOW_PRECISION=FP32

# ============= Logging =============
MAGNA_FLOW_LOG_LEVEL=INFO
MAGNA_FLOW_SAVE_RESULTS=true
MAGNA_FLOW_RESULTS_DIR=./results

# ============= API Keys (Optional) =============
# GITHUB_TOKEN=your_token_here
# GITLAB_TOKEN=your_token_here
# BITBUCKET_TOKEN=your_token_here
# CODEBERG_TOKEN=your_token_here

# ============= Deployment =============
# PYPI_TOKEN=your_pypi_token_here
# DOCKER_USERNAME=your_username
# DOCKER_PASSWORD=your_password
